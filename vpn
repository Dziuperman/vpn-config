#!/bin/sh

set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
# shellcheck disable=SC1091
. "$ROOT_DIR/scripts/common.sh"

PREFLIGHT_SCRIPT="$ROOT_DIR/scripts/preflight.sh"
DOCTOR_SCRIPT="$ROOT_DIR/scripts/doctor.sh"
VALIDATE_SCRIPT="$ROOT_DIR/scripts/validate.sh"
ANSIBLE_DIR="$ROOT_DIR/ansible"
ANSIBLE_LIMIT="${VPN_ANSIBLE_LIMIT:-vpn-prod}"
CLIENT_SUMMARY_FILE="$ROOT_DIR/.generated/client/connection-summary.txt"
CLIENT_SHADOWROCKET_RULES_FILE="$ROOT_DIR/.generated/client/shadowrocket-rules.conf"
CLIENT_URI_FILE="$ROOT_DIR/.generated/client/shadowrocket-vless.txt"
TUIC_URI_FILE="$ROOT_DIR/.generated/tuic/shadowrocket-tuic.txt"
SHADOWROCKET_RULES_URL="https://raw.githubusercontent.com/Dziuperman/vpn-config/refs/heads/main/client/shadowrocket/default.conf"

OVERRIDES_FILE=$(mktemp)
ANSIBLE_ARGS_FILE=$(mktemp)
TEMP_ENV_FILE=""
trap 'rm -f "$OVERRIDES_FILE" "$ANSIBLE_ARGS_FILE" ${TEMP_ENV_FILE:+"$TEMP_ENV_FILE"}' EXIT

usage() {
  cat <<'EOF'
Usage:
  ./vpn install [flags]
  ./vpn deploy [flags]
  ./vpn install-tuic [flags]
  ./vpn deploy-tuic [flags]
  ./vpn preflight [flags]
  ./vpn doctor [--strict]
  ./vpn validate
  ./vpn validate-tuic
  ./vpn status
  ./vpn status-tuic
  ./vpn logs [--tail N]
  ./vpn logs-tuic [--tail N]
  ./vpn restart
  ./vpn restart-tuic
  ./vpn client summary
  ./vpn client shadowrocket-rules
  ./vpn client shadowrocket-rules-url
  ./vpn client uri
  ./vpn client tuic-uri
  ./vpn env get <KEY>
  ./vpn env set <KEY> <VALUE>
  ./vpn help

Flags for install/deploy/preflight:
  --server-address <value>
  --vless-port <value>
  --telegram-socks-port <value>
  --image-tag <value>
  --log-level <value>
  --reality-dest <value>
  --reality-server-name <value>

Flags for install-tuic/deploy-tuic:
  --server-address <value>
  --tuic-port <value>
  --image-tag <value>
  --log-level <value>

Pass extra Ansible arguments to install/deploy after `--`:
  ./vpn install --vless-port 20443 -- --ask-vault-pass -k
  ./vpn deploy -- --vault-password-file .vault_pass.txt

Flags for doctor:
  --strict

Flags for logs:
  --tail <N>
EOF
}

fail_usage() {
  printf '%s\n\n' "$1" >&2
  usage >&2
  exit 2
}

ensure_env_file_exists() {
  if [ ! -f "$ENV_FILE" ]; then
    [ -f "$ENV_EXAMPLE_FILE" ] || fail "Missing $ENV_EXAMPLE_FILE"
    cp "$ENV_EXAMPLE_FILE" "$ENV_FILE"
  fi
}

upsert_file_key() {
  target_file=$1
  key=$2
  value=$3

  if grep -Eq "^${key}=" "$target_file"; then
    awk -v key="$key" -v value="$value" '
      $0 ~ ("^" key "=") { print key "=" value; next }
      { print }
    ' "$target_file" > "$target_file.tmp"
    mv "$target_file.tmp" "$target_file"
  else
    printf '%s=%s\n' "$key" "$value" >> "$target_file"
  fi
}

append_override() {
  printf '%s=%s\n' "$1" "$2" >> "$OVERRIDES_FILE"
}

append_ansible_arg() {
  printf '%s\n' "$1" >> "$ANSIBLE_ARGS_FILE"
}

apply_overrides_to_file() {
  target_file=$1

  if [ ! -s "$OVERRIDES_FILE" ]; then
    return 0
  fi

  while IFS='=' read -r key value; do
    [ -n "$key" ] || continue
    upsert_file_key "$target_file" "$key" "$value"
  done < "$OVERRIDES_FILE"
}

build_temp_env() {
  TEMP_ENV_FILE=$(mktemp)

  if [ -f "$ENV_FILE" ]; then
    cp "$ENV_FILE" "$TEMP_ENV_FILE"
  elif [ -f "$ENV_EXAMPLE_FILE" ]; then
    cp "$ENV_EXAMPLE_FILE" "$TEMP_ENV_FILE"
  else
    fail "Missing both $ENV_FILE and $ENV_EXAMPLE_FILE"
  fi

  apply_overrides_to_file "$TEMP_ENV_FILE"
}

run_script_with_env() {
  script=$1
  shift
  ENV_FILE="$TEMP_ENV_FILE" "$script" "$@"
}

require_ansible() {
  command -v ansible-playbook >/dev/null 2>&1 || fail "Missing required command: ansible-playbook"
  [ -d "$ANSIBLE_DIR" ] || fail "Missing ansible directory: $ANSIBLE_DIR"
}

build_ansible_extra_vars_file() {
  output_file=$(mktemp)

  if [ ! -s "$OVERRIDES_FILE" ]; then
    printf '%s\n' "$output_file"
    return 0
  fi

  while IFS='=' read -r key value; do
    [ -n "$key" ] || continue

    case "$key" in
      XRAY_SERVER_ADDRESS) ansible_key=xray_server_address ;;
      XRAY_VLESS_PORT) ansible_key=xray_vless_port ;;
      XRAY_TELEGRAM_SOCKS_PORT) ansible_key=xray_telegram_socks_port ;;
      XRAY_IMAGE_TAG) ansible_key=xray_image_tag ;;
      XRAY_LOG_LEVEL) ansible_key=xray_log_level ;;
      XRAY_REALITY_DEST) ansible_key=xray_reality_dest ;;
      XRAY_REALITY_SERVER_NAME) ansible_key=xray_reality_server_name ;;
      TUIC_SERVER_ADDRESS) ansible_key=tuic_server_address ;;
      TUIC_PORT) ansible_key=tuic_port ;;
      SINGBOX_IMAGE_TAG) ansible_key=singbox_image_tag ;;
      TUIC_LOG_LEVEL) ansible_key=tuic_log_level ;;
      *) fail "Unsupported override key for Ansible wrapper: $key" ;;
    esac

    printf "%s: '%s'\n" "$ansible_key" "$(printf '%s' "$value" | sed "s/'/''/g")" >> "$output_file"
  done < "$OVERRIDES_FILE"

  printf '%s\n' "$output_file"
}

run_ansible_playbook() {
  playbook_file=$1
  shift

  require_ansible
  extra_vars_file=$(build_ansible_extra_vars_file)
  set -- ansible-playbook "$playbook_file" -l "$ANSIBLE_LIMIT" "$@"

  if [ -s "$extra_vars_file" ]; then
    set -- "$@" --extra-vars "@$extra_vars_file"
  fi

  while IFS= read -r arg; do
    set -- "$@" "$arg"
  done < "$ANSIBLE_ARGS_FILE"

  if (
    cd "$ANSIBLE_DIR"
    "$@"
  ); then
    rc=0
  else
    rc=$?
  fi
  rm -f "$extra_vars_file"
  return "$rc"
}

require_generated_file() {
  [ -f "$1" ] || fail "Missing generated file: $1"
}

parse_override_flags() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --)
        shift
        while [ $# -gt 0 ]; do
          append_ansible_arg "$1"
          shift
        done
        return 0
        ;;
      --server-address)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override XRAY_SERVER_ADDRESS "$2"
        shift 2
        ;;
      --vless-port)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override XRAY_VLESS_PORT "$2"
        shift 2
        ;;
      --telegram-socks-port)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override XRAY_TELEGRAM_SOCKS_PORT "$2"
        shift 2
        ;;
      --image-tag)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override XRAY_IMAGE_TAG "$2"
        shift 2
        ;;
      --log-level)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override XRAY_LOG_LEVEL "$2"
        shift 2
        ;;
      --reality-dest)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override XRAY_REALITY_DEST "$2"
        shift 2
        ;;
      --reality-server-name)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override XRAY_REALITY_SERVER_NAME "$2"
        shift 2
        ;;
      *)
        fail_usage "Unknown flag: $1"
        ;;
    esac
  done
}

run_install() {
  parse_override_flags "$@"
  run_ansible_playbook playbooks/provision.yml
  run_ansible_playbook playbooks/deploy.yml
}

run_deploy() {
  parse_override_flags "$@"
  run_ansible_playbook playbooks/deploy.yml
}

parse_tuic_override_flags() {
  while [ $# -gt 0 ]; do
    case "$1" in
      --)
        shift
        while [ $# -gt 0 ]; do
          append_ansible_arg "$1"
          shift
        done
        return 0
        ;;
      --server-address)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override TUIC_SERVER_ADDRESS "$2"
        shift 2
        ;;
      --tuic-port)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override TUIC_PORT "$2"
        shift 2
        ;;
      --image-tag)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override SINGBOX_IMAGE_TAG "$2"
        shift 2
        ;;
      --log-level)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        append_override TUIC_LOG_LEVEL "$2"
        shift 2
        ;;
      *)
        fail_usage "Unknown flag: $1"
        ;;
    esac
  done
}

run_install_tuic() {
  parse_tuic_override_flags "$@"
  run_ansible_playbook playbooks/provision-tuic.yml
  run_ansible_playbook playbooks/deploy-tuic.yml
}

run_deploy_tuic() {
  parse_tuic_override_flags "$@"
  run_ansible_playbook playbooks/deploy-tuic.yml
}

run_preflight() {
  parse_override_flags "$@"
  build_temp_env
  run_script_with_env "$PREFLIGHT_SCRIPT"
}

run_doctor() {
  strict_flag=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --strict)
        strict_flag="--strict"
        shift
        ;;
      *)
        fail_usage "Unknown flag: $1"
        ;;
    esac
  done

  "$DOCTOR_SCRIPT" ${strict_flag:+"$strict_flag"}
}

run_logs() {
  tail_lines=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --tail)
        [ $# -ge 2 ] || fail_usage "Missing value for $1"
        tail_lines=$2
        shift 2
        ;;
      *)
        fail_usage "Unknown flag: $1"
        ;;
    esac
  done

  if [ -n "$tail_lines" ]; then
    docker compose -f "$COMPOSE_FILE" logs -f --tail "$tail_lines"
    return 0
  fi

  docker compose -f "$COMPOSE_FILE" logs -f
}

run_client() {
  [ $# -ge 1 ] || fail_usage "Missing client subcommand"

  case "$1" in
    summary)
      require_generated_file "$CLIENT_SUMMARY_FILE"
      cat "$CLIENT_SUMMARY_FILE"
      ;;
    shadowrocket-rules)
      require_generated_file "$CLIENT_SHADOWROCKET_RULES_FILE"
      cat "$CLIENT_SHADOWROCKET_RULES_FILE"
      ;;
    shadowrocket-rules-url)
      printf '%s\n' "$SHADOWROCKET_RULES_URL"
      ;;
    uri)
      require_generated_file "$CLIENT_URI_FILE"
      cat "$CLIENT_URI_FILE"
      ;;
    tuic-uri)
      require_generated_file "$TUIC_URI_FILE"
      cat "$TUIC_URI_FILE"
      ;;
    *)
      fail_usage "Unknown client subcommand: $1"
      ;;
  esac
}

run_env() {
  [ $# -ge 1 ] || fail_usage "Missing env subcommand"

  case "$1" in
    get)
      [ $# -eq 2 ] || fail_usage "Usage: ./vpn env get <KEY>"
      [ -f "$ENV_FILE" ] || fail "Missing $ENV_FILE"
      if ! grep -Eq "^$2=" "$ENV_FILE"; then
        fail "Missing env key: $2"
      fi
      awk -F= -v key="$2" '$1 == key {sub(/^[^=]*=/, ""); print; exit}' "$ENV_FILE"
      ;;
    set)
      [ $# -eq 3 ] || fail_usage "Usage: ./vpn env set <KEY> <VALUE>"
      ensure_env_file_exists
      upsert_file_key "$ENV_FILE" "$2" "$3"
      printf '%s=%s\n' "$2" "$3"
      ;;
    *)
      fail_usage "Unknown env subcommand: $1"
      ;;
  esac
}

main() {
  [ $# -ge 1 ] || {
    usage
    exit 0
  }

  command_name=$1
  shift

  case "$command_name" in
    install)
      run_install "$@"
      ;;
    deploy)
      run_deploy "$@"
      ;;
    install-tuic)
      run_install_tuic "$@"
      ;;
    deploy-tuic)
      run_deploy_tuic "$@"
      ;;
    preflight)
      run_preflight "$@"
      ;;
    doctor)
      run_doctor "$@"
      ;;
    validate)
      [ $# -eq 0 ] || fail_usage "validate does not accept flags"
      "$VALIDATE_SCRIPT"
      ;;
    validate-tuic)
      [ $# -eq 0 ] || fail_usage "validate-tuic does not accept flags"
      "$ROOT_DIR/scripts/validate-tuic.sh"
      ;;
    status)
      [ $# -eq 0 ] || fail_usage "status does not accept flags"
      docker compose -f "$COMPOSE_FILE" ps
      ;;
    status-tuic)
      [ $# -eq 0 ] || fail_usage "status-tuic does not accept flags"
      docker compose --env-file "$ROOT_DIR/.env.tuic" -f "$ROOT_DIR/compose.tuic.yaml" ps
      ;;
    logs)
      run_logs "$@"
      ;;
    logs-tuic)
      if [ $# -gt 0 ] && [ "$1" = "--tail" ]; then
        [ $# -eq 2 ] || fail_usage "Missing value for $1"
        docker compose --env-file "$ROOT_DIR/.env.tuic" -f "$ROOT_DIR/compose.tuic.yaml" logs -f --tail "$2"
      elif [ $# -eq 0 ]; then
        docker compose --env-file "$ROOT_DIR/.env.tuic" -f "$ROOT_DIR/compose.tuic.yaml" logs -f
      else
        fail_usage "Unknown flag: $1"
      fi
      ;;
    restart)
      [ $# -eq 0 ] || fail_usage "restart does not accept flags"
      docker compose -f "$COMPOSE_FILE" restart
      ;;
    restart-tuic)
      [ $# -eq 0 ] || fail_usage "restart-tuic does not accept flags"
      docker compose --env-file "$ROOT_DIR/.env.tuic" -f "$ROOT_DIR/compose.tuic.yaml" restart
      ;;
    client)
      run_client "$@"
      ;;
    env)
      run_env "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      fail_usage "Unknown command: $command_name"
      ;;
  esac
}

main "$@"
